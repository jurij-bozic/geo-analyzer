{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "outputs": ["dist/**", ".next/**", ".turbo/cache/**"],
      "cache": true,
      "dependsOn": ["^build"]
    },
    "dev": {
      "persistent": true,
      "cache": false
    },
    "lint": {
      "outputs": [".eslintcache"],
      "cache": true
    },
    "type-check": {
      "cache": true,
      "dependsOn": ["^build"]
    },
    "start": {
      "persistent": true,
      "cache": false
    }
  }
}
